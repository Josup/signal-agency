{
  "version": 2,
  "framework": null,
  "buildCommand": "echo done",
  "outputDirectory": ".",
  "routes": [
    { "src": "/journal", "dest": "/journal.html" },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/404.html", "status": 404 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate" }
      ]
    }
  ]
}
